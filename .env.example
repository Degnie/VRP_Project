# Database Configuration
DATABASE_URL=postgresql://vrp_user:vrp_pass@localhost:5432/vrp_dev
MONGODB_URL=mongodb://vrp_user:vrp_pass@localhost:27017/vrp_dev

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Solver Configuration
MAX_ITERATIONS=10000
INITIAL_TEMPERATURE=1000.0
COOLING_FACTOR=0.95
USE_RUIN_RECREATE=true

# DRL Configuration (future)
DRL_MODEL_PATH=./models/drl_policy.pt
USE_DRL_CALIBRATION=false

# Logging
LOG_LEVEL=INFO
