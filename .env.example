# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=vrp_password
POSTGRES_DB=vrp_db

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=vrp_db

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Solver
SOLVER_TIMEOUT_SECONDS=30

# OSRM (routing sobre calles reales; vacío = usa distancia euclídea)
# Requiere levantar el servicio OSRM (ver `make osrm-prepare` y docker-compose.yml)
OSRM_URL=http://localhost:5000
OSRM_MAX_TABLE_SIZE=100
OSRM_TIMEOUT_SECONDS=5
